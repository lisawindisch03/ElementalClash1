from __future__ import annotations
from typing import Dict, List, Type, Optional
import random

from creatures.base_creature import Creature

class CreatureFactory:
    _registry: Dict[str, Type[Creature]] = {}

    @staticmethod
    def register_creature(name: str, creature_cls: Type[Creature]) -> None:
        CreatureFactory._registry[name] = creature_cls

    @staticmethod
    def create_creature(name: str) -> Optional[Creature]:
        if not isinstance(name, str) or name not in CreatureFactory._registry:
            return None
        
        creature_cls = CreatureFactory._registry[name]
        return creature_cls()

    @staticmethod
    def get_all_creature_names() -> List[str]:
        return list(CreatureFactory._registry.keys())

    @staticmethod
    def create_random_hand(count: int = 3) -> List[Creature]:
        if count <= 0:
            return []
        
        available_names = CreatureFactory.get_all_creature_names()
        if not available_names:
            return []
        
        count = min(count, len(available_names))
        selected_names = random.sample(available_names, count)
        
         return [creature for name in selected_names 
                if (creature := CreatureFactory.create_creature(name))]
    
    @staticmethod
    def create_preset_hand(creature_names: List[str]) -> List[Creature]:
        if not creature_names:
            return []
        
        return [creature for name in creature_names 
                if (creature := CreatureFactory.create_creature(name))]


# Register all available creature types
    @staticmethod
    def initialize_all_creatures() -> None:
        # Import all creature classes
        from creatures.fire_creatures import Emberfox, Infernosaur, Blazewolf
        from creatures.water_creatures import Aquashell, Frostbite, Tidalfin
        from creatures.earth_creatures import Stoneguard, Terraclaw, Ironback
        from creatures.air_creatures import Zephyrwing, Cloudstrider, Tempestowl
        from creatures.lightning_creatures import Sparkfang, Thundermane, Voltwing

        creatures = [
            # Fire (3)
            ("Emberfox", Emberfox), ("Infernosaur", Infernosaur), ("Blazewolf", Blazewolf),
            # Water (3)
            ("Aquashell", Aquashell), ("Frostbite", Frostbite), ("Tidalfin", Tidalfin),
            # Earth (3)
            ("Stoneguard", Stoneguard), ("Terraclaw", Terraclaw), ("Ironback", Ironback),
            # Air (3)
            ("Zephyrwing", Zephyrwing), ("Cloudstrider", Cloudstrider), ("Tempestowl", Tempestowl),
            # Lightning (3)
            ("Sparkfang", Sparkfang), ("Thundermane", Thundermane), ("Voltwing", Voltwing)
        ]
        
        for name, creature_cls in creatures:
            CreatureFactory.register_creature(name, creature_cls)
