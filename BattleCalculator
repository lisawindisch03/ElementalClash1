from __future__ import annotations
from typing import Dict, Any, Tuple, List
import random

from creatures.base_creature import Creature
from abilities.ability import Ability

# Battle calculation logic
class BattleCalculator:
    
    # Calculate damage dealt from attacker to defender
    @staticmethod
    def calculate_damage(
        attacker: Creature, 
        defender: Creature, 
        ability_power: int = 0,
        is_defending: bool = False
    ) -> Dict[str, Any]:
        base_damage = max(1, (attacker.attack + ability_power) - defender.defense)
        elemental_modifier = attacker.get_elemental_bonus(defender.element)
        elemental_damage = max(1, int(base_damage * elemental_modifier))
        final_damage = max(1, int(elemental_damage * (0.5 if is_defending else 1.0)))
        
        return {
            "base_damage": base_damage,
            "elemental_modifier": elemental_modifier,
            "elemental_damage": elemental_damage,
            "final_damage": final_damage,
            "is_defending": is_defending,
            "attacker_element": attacker.element,
            "defender_element": defender.element
        }

    # Get elemental modifier from creature.py
    @staticmethod
    def get_elemental_modifier(attacker: Creature, defender: Creature) -> float:
        return attacker.get_elemental_bonus(defender.element)

    # Calculate overflow damage if hp > 0
    @staticmethod
    def calculate_overflow_damage(creature: Creature, damage_amount: int) -> int:
        return max(0, damage_amount - creature.current_hp)
    
    @staticmethod
    def apply_damage_with_overflow(creature: Creature, damage_amount: int) -> Dict[str, Any]:
        # Calculate overflow before applying damage
        overflow = BattleCalculator.calculate_overflow_damage(creature, damage_amount)
        
        actual_damage, is_defeated = creature.take_damage(damage_amount)
        
        return {
            "actual_damage": actual_damage,
            "is_defeated": is_defeated,
            "overflow_damage": overflow,
            "creature_hp_after": creature.current_hp
        }

    # process execute method from ability.py
    @staticmethod
    def process_ability(ability, user_creature: Creature, target_creature: Creature) -> Dict[str, Any]:
        ability_data = ability.execute(user_creature, target_creature)
        effect_type = ability_data["effect_type"]
        result = {"effect_type": effect_type, "ability_data": ability_data, "success": True}
        
        if effect_type == "damage":
            result["damage_result"] = BattleCalculator.calculate_damage(
                user_creature, target_creature, ability_data["power"]
            )
        elif effect_type == "heal":
            heal_amount = min(ability_data["power"], user_creature.max_hp - user_creature.current_hp)
            result["heal_amount"] = user_creature.heal(heal_amount)
        elif effect_type in ["buff", "debuff", "special"]:
            result["power"] = ability_data["power"]
            result["message"] = f"{ability.name} uses {effect_type} effect!"
        else:
            result["success"] = False
            result["message"] = f"Unknown ability type: {effect_type}"
        
        return result

    @staticmethod
    def resolve_speed_order(creature1: Creature, creature2: Creature, human_creature: Creature = None) -> Tuple[Creature, Creature]:
        if creature1.speed != creature2.speed:
            return (creature1, creature2) if creature1.speed > creature2.speed else (creature2, creature1)
        if human_creature == creature1:
            return (creature1, creature2)
        if human_creature == creature2:
            return (creature2, creature1)
        return (creature1, creature2) if random.random() < 0.5 else (creature2, creature1)


    # Helper: Calculate score for an ability based on its effect_type
    @staticmethod
    def _score_ability(
        ability,
        user_creature: Creature,
        opponent_creature: Creature
    ) -> float:
        ability_data = ability.execute(user_creature, opponent_creature)
        effect_type = ability_data["effect_type"]
        
        if effect_type == "damage":
            damage_result = BattleCalculator.calculate_damage(
                user_creature, opponent_creature, ability_data["power"]
            )
            return damage_result["final_damage"] + 2
        
        elif effect_type == "heal" and user_creature.current_hp < user_creature.max_hp * 0.6:
            return min(ability_data["power"], user_creature.max_hp - user_creature.current_hp)
        
        else:  # buff, debuff, special
            return 15

    # Feature 2: 
    @staticmethod
    def choose_smart_action(
        user_creature: Creature,
        opponent_creature: Creature,
        user_ep: int,
        user_hp_ratio: float = 1.0
    ) -> Dict[str, Any]:
        actions = [{"action": 1, "score": BattleCalculator.calculate_damage(user_creature, opponent_creature)["final_damage"], "type": "basic_attack"}]
        
  
        for i, ability in enumerate(user_creature.abilities):
            if user_ep >= ability.ep_cost:
                actions.append({
                    "action": i + 2,
                    "score": BattleCalculator._score_ability(ability, user_creature, opponent_creature),
                    "type": f"ability_{i + 1}",
                    "ability_name": ability.name
                })
        
        # Defend if HP is low
        if (user_creature.current_hp / user_creature.max_hp < 0.5) or (user_hp_ratio < 0.4):
            incoming_damage = BattleCalculator.calculate_damage(opponent_creature, user_creature)["final_damage"]
            actions.append({"action": 4, "score": incoming_damage * 0.5, "type": "defend"})
        
        return max(actions, key=lambda x: x["score"]) if actions else {"action": 1, "type": "basic_attack", "score": 0}


